<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scatch</title>

    <!-- Remix Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
</head>

<body class="font-['Inter'] bg-[#FAFAFA] text-zinc-800">

    <nav class="w-full fixed top-0 left-0 z-50 px-10 py-5 bg-white/90 backdrop-blur-md border-b border-zinc-200 flex items-center justify-between">

        <!-- Logo -->
       <h3 class="text-2xl font-bold tracking-[0.25em] text-zinc-900">
    SCATCH
</h3>

        <% var loggedin = typeof loggedin !== "undefined" ? loggedin : false %>

        <% if(loggedin){ %>
            <div class="flex items-center gap-8 text-[15px] font-medium">

                <a href="/shop"
                   class="hover:text-blue-600 transition duration-200">
                    Shop
                </a>

                <a href="/cart"
                   class="hover:text-blue-600 transition duration-200 flex items-center gap-1">
                    <i class="ri-shopping-bag-line"></i>
                    Cart
                </a>

                <a href="/account"
                   class="hover:text-blue-600 transition duration-200 flex items-center gap-1">
                    <i class="ri-user-line"></i>
                    My Account
                </a>

                <a href="/logout"
                   class="text-red-500 hover:text-red-600 transition duration-200">
                    Logout
                </a>

            </div>
        <% } %>

    </nav>