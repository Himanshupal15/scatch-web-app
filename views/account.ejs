<%- include('./partials/header') %>

<div class="pt-24"></div>

<div class="w-full min-h-screen bg-[#FAFAFA] px-10 lg:px-20 py-10">
    <div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-sm p-10">
        <h1 class="text-4xl font-bold text-zinc-900 mb-6">My Account</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-4">
                <p class="text-zinc-600">Full Name</p>
                <p class="text-xl font-semibold text-zinc-900"><%= user.fullname || 'Not set' %></p>
            </div>

            <div class="space-y-4">
                <p class="text-zinc-600">Email</p>
                <p class="text-xl font-semibold text-zinc-900"><%= user.email %></p>
            </div>
        </div>

        <div class="mt-10 space-y-4">
            <div>
                <p class="text-zinc-600">Contact</p>
                <p class="text-xl font-semibold text-zinc-900"><%= user.contact || 'Not provided' %></p>
            </div>

            <div>
                <p class="text-zinc-600">Orders</p>
                <p class="text-xl font-semibold text-zinc-900"><%= user.orders?.length || 0 %> past order(s)</p>
            </div>
        </div>

        <div class="mt-12">
            <a href="/shop" class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-6 py-3 text-white hover:bg-zinc-800 transition">
                <i class="ri-arrow-left-line"></i>
                Back to shop
            </a>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>