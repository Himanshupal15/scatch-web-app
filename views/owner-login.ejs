<%- include('./partials/header') %>

<div class="pt-24"></div>

<div class="min-h-screen bg-[#FAFAFA] flex items-center justify-center px-6 py-10">

    <div class="w-full max-w-md">

        <!-- Login Card -->
        <div class="bg-white rounded-3xl shadow-lg p-10">

            <!-- Heading -->
            <div class="text-center mb-10">

                <h2 class="font-['Playfair_Display'] text-4xl font-bold text-zinc-900">
                    Admin Access
                </h2>

                <p class="text-zinc-500 mt-3">
                    Sign in to manage products and store settings.
                </p>

            </div>

            <!-- Form -->
            <form autocomplete="off" action="/owners/login" method="post" class="space-y-5">
                <input type="text" name="fakeUsername" autocomplete="username" style="display:none" />
                <input type="password" name="fakePassword" autocomplete="current-password" style="display:none" />

                <!-- Email -->
                <div>

                    <label class="block text-sm font-medium text-zinc-700 mb-2">
                        Email Address
                    </label>

                    <input
                        autocomplete="username"
                        class="w-full bg-zinc-50 px-5 py-4 border border-zinc-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
                        type="email"
                        placeholder="admin@example.com"
                        name="email"
                        required>

                </div>

                <!-- Password -->
                <div>

                    <label class="block text-sm font-medium text-zinc-700 mb-2">
                        Password
                    </label>

                    <input
                        autocomplete="current-password"
                        class="w-full bg-zinc-50 px-5 py-4 border border-zinc-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
                        type="password"
                        placeholder="Enter your password"
                        name="password"
                        required>

                </div>

                <!-- Login Button -->
                <button
                    type="submit"
                    class="w-full py-4 bg-zinc-900 text-white rounded-2xl font-medium hover:bg-black transition">

                    Login to Dashboard

                </button>

            </form>

            <!-- Security Note -->
            <div class="mt-8 text-center">

                <p class="text-sm text-zinc-400">
                    Restricted access. Authorized personnel only.
                </p>

            </div>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>