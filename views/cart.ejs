<%- include('./partials/header') %>

<div class="pt-24"></div>

<div class="w-full min-h-screen bg-[#FAFAFA] px-10 lg:px-20 py-10">

    <div class="flex justify-between items-center mb-8">
        <a href="/shop" class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-4 py-2 text-zinc-700 hover:bg-zinc-100 transition">
            <i class="ri-arrow-left-line"></i>
            Continue shopping
        </a>
    </div>

    <div class="flex flex-col lg:flex-row gap-10">

        <!-- Cart Items -->
        <div class="lg:w-[70%]">

            <% const cartHasProducts = user.cart && user.cart.some(function(item){ return item.product; }); %>
            <% if (!cartHasProducts) { %>
                <div class="bg-white rounded-3xl shadow-sm p-8 mb-8 text-center">
                    <h2 class="text-3xl font-semibold text-zinc-900 mb-3">Your cart is empty</h2>
                    <p class="text-zinc-600 mb-6">Add products from the shop to start building your order.</p>
                    <a href="/shop" class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-6 py-3 text-white hover:bg-zinc-800 transition">
                        <i class="ri-shopping-bag-line"></i>
                        Browse shop
                    </a>
                </div>
            <% } else { %>
                <% user.cart.forEach(function(item){ %>
                    <% if (!item.product) return; %>

                <div class="bg-white rounded-3xl shadow-sm hover:shadow-lg transition duration-300 p-8 mb-8 cart-item" data-product-id="<%= item.product._id %>">

                <div class="flex flex-col md:flex-row gap-8">

                    <!-- Product Image -->
                    <div class="md:w-[35%]">
                        <div class="rounded-2xl overflow-hidden border border-zinc-200">

                            <div class="w-full h-72 flex justify-center items-center bg-[<%= item.product.bgcolor %>]">

                                <img
                                    class="h-60 object-contain transition duration-300 hover:scale-105"
                                    src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>"
                                    alt="<%= item.product.name %>">

                            </div>

                        </div>
                    </div>

                    <!-- Product Details -->
                    <div class="md:w-[65%] flex flex-col justify-between">

                        <div>

                            <div class="flex justify-between items-start">

                                <div>
                                    <h3 class="text-2xl font-semibold text-zinc-800">
                                        <%= item.product.name %>
                                    </h3>

                                    <p class="text-zinc-500 mt-1">
                                        Premium Collection
                                    </p>
                                </div>

                                <a
                                    href="/cart/remove/<%= item.product._id %>"
                                    class="text-red-500 hover:text-red-600 font-medium">
                                    Remove
                                </a>

                            </div>

                            <div class="mt-6 space-y-3">

                                <div class="flex justify-between">
                                    <span class="text-zinc-600">Price</span>

                                    <span class="font-medium">
                                        ₹ <%= item.product.price %>
                                    </span>
                                </div>

                                <div class="flex justify-between">
                                    <span class="text-zinc-600">Discount</span>

                                    <span class="text-green-600 font-medium">
                                        - ₹ <%= Number(item.product.discount) %>
                                    </span>
                                </div>

                            </div>

                        </div>

                        <!-- Quantity -->
                        <div class="flex justify-between items-center mt-8">


                                <div class="flex items-center gap-3">

                                <button type="button" data-product-id="<%= item.product._id %>" class="qty-btn decrease w-10 h-10 rounded-full bg-zinc-100 hover:bg-zinc-200 transition flex items-center justify-center">
                                    <i class="ri-subtract-line"></i>
                                </button>

                                <div class="px-5 py-2 rounded-xl bg-zinc-100 font-semibold qty-value" data-product-id="<%= item.product._id %>">
                                    <%= item.quantity || 1 %>
                                </div>

                                <button type="button" data-product-id="<%= item.product._id %>" class="qty-btn increase w-10 h-10 rounded-full bg-zinc-100 hover:bg-zinc-200 transition flex items-center justify-center">
                                    <i class="ri-add-line"></i>
                                </button>

                            </div>

                            <div class="text-right">

                                <p class="text-sm text-zinc-500">
                                    Item Total
                                </p>

                                <h3 class="text-2xl font-bold text-zinc-900">
                                    ₹ <span class="item-subtotal" data-product-id="<%= item.product._id %>"><%= (item.product.price - Number(item.product.discount)) * (item.quantity || 1) %></span>
                                </h3>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

                <% }) %>
            <% } %>

        </div>

        <!-- Order Summary -->
        <div class="lg:w-[30%]">

            <div class="sticky top-28 bg-white rounded-3xl shadow-sm p-8">

                <h2 class="text-4xl font-bold text-zinc-900 mb-8">
                    Order Summary
                </h2>

                <div class="space-y-5">

                    <div class="flex justify-between">
                        <span class="text-zinc-600">
                            Cart Total
                        </span>

                        <span class="font-medium">
                            ₹ <span id="items-total"><%= itemsTotal %></span>
                        </span>
                    </div>

                    <div class="flex justify-between">
                        <span class="text-zinc-600">
                            Shipping
                        </span>

                        <span class="text-green-600 font-medium">
                            FREE
                        </span>
                    </div>

                    <div class="flex justify-between">
                        <span class="text-zinc-600">
                            Platform Fee
                        </span>

                        <span class="font-medium">
                            ₹ 20
                        </span>
                    </div>

                </div>

                <div class="w-full h-px bg-zinc-200 my-8"></div>

                <div class="flex justify-between items-center">

                    <h3 class="text-xl font-semibold">
                        Total Amount
                    </h3>

                    <h3 class="text-3xl font-bold text-green-600">
                        ₹ <span id="bill-total"><%= bill %></span>
                    </h3>

                </div>

            </div>

        </div>

    </div>

</div>

<script>
document.addEventListener('click', async function(e){
    const btn = e.target.closest('.qty-btn');
    if (!btn) return;
    const productId = btn.dataset.productId;
    const action = btn.classList.contains('increase') ? 'increase' : 'decrease';
    try {
        const res = await fetch('/cart/update-quantity', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ productId, action })
        });
        const data = await res.json();
        if (!data.success) return;

        const qtyEl = document.querySelector(`.qty-value[data-product-id="${productId}"]`);
        if (qtyEl) qtyEl.textContent = data.itemQuantity;

        const subEl = document.querySelector(`.item-subtotal[data-product-id="${productId}"]`);
        if (subEl) subEl.textContent = data.itemSubtotal;

        const itemsTotalEl = document.getElementById('items-total');
        if (itemsTotalEl) itemsTotalEl.textContent = data.itemsTotal;

        const billEl = document.getElementById('bill-total');
        if (billEl) billEl.textContent = data.bill;

        if (data.removed) {
            const cartItem = document.querySelector(`.cart-item[data-product-id="${productId}"]`);
            if (cartItem) cartItem.remove();
            const anyItems = document.querySelectorAll('.cart-item').length;
            if (!anyItems) location.reload();
        }
    } catch (err) {
        console.error(err);
    }
});
</script>

<%- include('./partials/footer') %>